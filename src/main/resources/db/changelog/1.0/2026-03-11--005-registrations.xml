<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.6.xsd">

    <changeSet id="2026-03-11--005-registrations" author="stelv1k">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="registrations"/>
            </not>
        </preConditions>

        <createTable tableName="registrations">
            <column name="id" type="INT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="event_id" type="INT">
                <constraints nullable="false"/>
            </column>

            <column name="user_id" type="INT">
                <constraints nullable="false"/>
            </column>

            <column name="registration_date" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="registrations"
                baseColumnNames="event_id"
                constraintName="fk_registrations_event"
                referencedTableName="events"
                referencedColumnNames="id"/>

        <addForeignKeyConstraint
                baseTableName="registrations"
                baseColumnNames="user_id"
                constraintName="fk_registrations_user"
                referencedTableName="users"
                referencedColumnNames="id"/>

        <addUniqueConstraint
                tableName="registrations"
                columnNames="event_id, user_id"
                constraintName="uk_registrations_event_user"/>
    </changeSet>

</databaseChangeLog>